<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin – Amerikabreven</title>
  <link rel="stylesheet" href="/css/stil.css">
</head>
<body>
  <header>
    <div class="header-inner">
      <h1>Amerikabreven</h1>
      <p class="undertitel">Administration</p>
    </div>
  </header>

  <main>
    <div class="login-wrap">
      <h2>Adminlogin</h2>
      <% if (fel) { %>
        <p class="login-fel"><%= fel %></p>
      <% } %>
      <form method="POST" action="/admin/login">
        <div class="form-rad">
          <label for="losenord">Lösenord</label>
          <input type="password" id="losenord" name="losenord" required autofocus>
        </div>
        <button type="submit" class="skicka-knapp">Logga in</button>
      </form>
    </div>
  </main>

  <footer>
    &copy; Amerikabreven
  </footer>
</body>
</html>
